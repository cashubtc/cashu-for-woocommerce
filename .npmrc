# Minimum release age (days). Any `npm install`, `npm update`, or fresh
# `npm install <pkg>` in this project will refuse to resolve to a version
# released less than this many days ago. Defends against hijacked-tag /
# bad-release supply-chain incidents that haven't had time to be spotted
# by the community yet. Pairs with the matching `cooldown` in
# .github/dependabot.yml - Dependabot won't propose the bump, and even
# if someone runs install manually, npm won't resolve to it.
min-release-age=7
