{
  "name": "cashu-for-woocommerce",
  "description": "Cashu For WooCommerce adds a secure Cashu payment gateway to your WooCommerce store",
  "version": "0.4.0",
  "author": "Rob Woodgate",
  "license": "MIT",
  "keywords": [
    "cashu"
  ],
  "dependencies": {
    "@cashu/cashu-ts": "^4.5.1",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@prettier/plugin-php": "^0.25.0",
    "@types/jquery": "^4.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@wordpress/env": "^11.8.0",
    "git-cliff": "^2.12.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "plugins": [
      "@prettier/plugin-php"
    ],
    "printWidth": 90,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true,
    "braceStyle": "1tbs"
  },
  "scripts": {
    "lint:php:check": "composer lint:check",
    "lint:php": "composer lint:fix",
    "lint:css:check": "stylelint \"assets/**/*.css\"",
    "lint:css": "stylelint \"assets/**/*.css\" --fix",
    "lint:ts:check": "tsc --noEmit",
    "test:ts": "vitest run",
    "test:ts:coverage": "vitest run --coverage",
    "test:ts:watch": "vitest",
    "lint:check": "npm run lint:php:check && npm run lint:css:check && npm run lint:ts:check",
    "lint": "npm run lint:php && npm run lint:css",
    "format:check": "prettier -c cashu-for-woocommerce.php src tests assets",
    "format": "prettier -w cashu-for-woocommerce.php src tests assets",
    "changelog": "git-cliff -o CHANGELOG.md",
    "build": "vite build && npm run format && npm run lint && npm run lint:check",
    "check": "npm run format:check && npm run lint:check && npm run test:ts && composer test",
    "fix": "npm run format && npm run lint",
    "wp-env:start": "wp-env start",
    "wp-env:seed-store": "bash scripts/seed-store.sh",
    "wp-env:stop": "wp-env stop",
    "wp-env:destroy": "wp-env destroy",
    "wp-env:reset": "wp-env reset && npm run wp-env:seed-store",
    "wp-env:tunnel": "bash scripts/tunnel.sh",
    "wp-env:tunnel-reset": "bash scripts/tunnel-reset.sh",
    "test:e2e": "playwright test"
  }
}
