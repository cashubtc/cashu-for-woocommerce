#: src/Admin/GlobalSettings.php:13
msgid "Cashu Settings"
msgstr "Paramètres Cashu"

#: src/Admin/GlobalSettings.php:40 src/Admin/GlobalSettings.php:132
msgid "Unified (Auto)"
msgstr "Unifié (Auto)"

#: src/Admin/GlobalSettings.php:41 src/Admin/GlobalSettings.php:133
#: src/Gateway/CashuGateway.php:172 src/Gateway/CashuGateway.php:1044
msgid "Cashu"
msgstr "Cashu"

#: src/Admin/GlobalSettings.php:42 src/Admin/GlobalSettings.php:134
#: src/Gateway/CashuGateway.php:173 src/Gateway/CashuGateway.php:1045
msgid "Lightning"
msgstr "Lightning"

#: src/Admin/GlobalSettings.php:44
msgid "Requires Cashu + Lightning"
msgstr "Nécessite Cashu + Lightning"

#: src/Admin/GlobalSettings.php:53
msgid "Cashu payments"
msgstr "Paiements Cashu"

#: src/Admin/GlobalSettings.php:55
msgid ""
"Accept ecash payments directly to your lightning address via any Cashu mint."
msgstr ""
"Acceptez des paiements ecash directement vers votre adresse Lightning via "
"n’importe quel mint Cashu."

#: src/Admin/GlobalSettings.php:62
msgid "Lightning address"
msgstr "Adresse Lightning"

#: src/Admin/GlobalSettings.php:65
msgid "Where melted payments are sent, either a lightning address or LNURL."
msgstr ""
"Destination des paiements fondus, soit une adresse Lightning, soit un LNURL."

#: src/Admin/GlobalSettings.php:73
msgid "Trusted Mint URL"
msgstr "URL du mint de confiance"

#: src/Admin/GlobalSettings.php:76
msgid "A mint you trust to act as your intermediary."
msgstr "Un mint en qui vous avez confiance pour servir d’intermédiaire."

#: src/Admin/GlobalSettings.php:89
msgid "Payment paths"
msgstr "Options de paiement"

#: src/Admin/GlobalSettings.php:91
msgid ""
"Choose which payment options are offered at checkout and which one opens "
"first. Unified (Auto) is a single BIP-321 QR that works with both Cashu and "
"Lightning wallets, and needs both options enabled."
msgstr ""
"Choisissez les options de paiement proposées au passage en caisse et celle "
"qui s’ouvre en premier. Unifié (Auto) est un QR BIP-321 unique compatible "
"avec les portefeuilles Cashu et Lightning, et nécessite l’activation des "
"deux options."

#: src/Admin/GlobalSettings.php:105
msgid "Show payment options"
msgstr "Afficher les options de paiement"

#: src/Admin/GlobalSettings.php:107
msgid ""
"Unified (Auto) — single BIP-321 QR. Requires both Cashu and Lightning "
"enabled."
msgstr ""
"Unifié (Auto) — un QR BIP-321 unique. Nécessite l’activation de Cashu et de "
"Lightning."

#: src/Admin/GlobalSettings.php:115
msgid "Cashu (NUT-18 payment request)."
msgstr "Cashu (demande de paiement NUT-18)."

#: src/Admin/GlobalSettings.php:123
msgid "Lightning (BOLT11 invoice)."
msgstr "Lightning (facture BOLT11)."

#: src/Admin/GlobalSettings.php:129
msgid "Default tab"
msgstr "Onglet par défaut"

#: src/Admin/GlobalSettings.php:137
msgid ""
"Which tab opens first at checkout. Snaps to the first enabled tab if the "
"chosen one is disabled."
msgstr ""
"Quel onglet s’ouvre en premier au passage en caisse. Bascule vers le premier "
"onglet activé si celui choisi est désactivé."

#: src/Admin/GlobalSettings.php:149
msgid "Advanced"
msgstr "Avancé"

#: src/Admin/GlobalSettings.php:154 src/CashuWCPlugin.php:375
msgid "Debug log"
msgstr "Journal de débogage"

#: src/Admin/GlobalSettings.php:156
msgid "Enable logging"
msgstr "Activer la journalisation"

#. translators: %s is a link to WooCommerce logs page
#: src/Admin/GlobalSettings.php:160
msgid "Log events to the WooCommerce logs, <a href=\"%s\">view logs</a>."
msgstr ""
"Enregistrer les événements dans les journaux WooCommerce, <a href=\"%s"
"\">voir les journaux</a>."

#: src/Admin/OrderMetaBox.php:32
msgid "Cashu Payment"
msgstr "Paiement Cashu"

#: src/Admin/OrderMetaBox.php:46
msgid "Not a Cashu order."
msgstr "Cette commande n’est pas réglée en Cashu."

#: src/Admin/OrderMetaBox.php:65
msgid "Paid."
msgstr "Réglée."

#: src/Admin/OrderMetaBox.php:66
msgid "Open the receipt page to verify or run recovery."
msgstr "Ouvrez la page de paiement pour vérifier ou lancer une récupération."

#: src/Admin/OrderMetaBox.php:68
msgid ""
"Open the customer's receipt page in a new tab. If the payment settled at the "
"mint but never claimed (e.g. the customer's browser died mid-payment), the "
"page-load watcher will mint the proofs and finalize the order."
msgstr ""
"Ouvre la page de paiement du client dans un nouvel onglet. Si le paiement a "
"abouti au mint mais n’a jamais été réclamé (par exemple, le navigateur du "
"client s’est fermé pendant le paiement), le moniteur de la page va émettre "
"les preuves et finaliser la commande."

#: src/Admin/OrderMetaBox.php:73
msgid "Open customer payment page"
msgstr "Ouvrir la page de paiement du client"

#: src/Admin/OrderMetaBox.php:77
msgid "Mint"
msgstr "Mint"

#: src/Admin/OrderMetaBox.php:82
msgid "Mint quote (customer payment)"
msgstr "Devis d’émission (paiement client)"

#: src/Admin/OrderMetaBox.php:87
msgid "Melt quote (vendor payment)"
msgstr "Devis de fusion (paiement marchand)"

#: src/Admin/OrderMetaBox.php:92
msgid "Archived mint quotes"
msgstr "Devis d’émission archivés"

#: src/Admin/OrderMetaBox.php:93
msgid ""
"Previous customer-payment quotes for this order, kept for out-of-band "
"recovery if a customer paid one before rotation."
msgstr ""
"Devis de paiement client précédents pour cette commande, conservés pour une "
"récupération hors flux si un client a payé l’un d’eux avant rotation."

#: src/Admin/OrderMetaBox.php:107
msgid "Archived melt quotes"
msgstr "Devis de fusion archivés"

#: src/Admin/OrderMetaBox.php:108
msgid ""
"Previous vendor-payout quotes for this order, with the underlying BOLT11 "
"invoice for forensic lookup against the mint."
msgstr ""
"Devis de paiement marchand précédents pour cette commande, avec la facture "
"BOLT11 sous-jacente pour vérification auprès du mint."

#: src/Admin/OrderMetaBox.php:119
msgid "BOLT11 invoice"
msgstr "Facture BOLT11"

#: src/Admin/ValidateGlobalSettings.php:60
msgid "Trusted Mint URL must be a valid URL."
msgstr "L’URL du mint de confiance doit être une URL valide."

#: src/Admin/ValidateGlobalSettings.php:66
msgid "Trusted Mint URL must use https."
msgstr "L’URL du mint de confiance doit utiliser HTTPS."

#. translators: %s: mint URL
#: src/Admin/ValidateGlobalSettings.php:109
msgid "Could not reach the mint at %s. Check the URL and try again."
msgstr ""
"Impossible de joindre le mint à l’adresse %s. Vérifiez l’URL et réessayez."

#. translators: 1: mint URL, 2: HTTP status code
#: src/Admin/ValidateGlobalSettings.php:118
msgid "Mint at %1$s returned HTTP %2$d for /v1/info — is this a Cashu mint?"
msgstr ""
"Le mint à l’adresse %1$s a renvoyé HTTP %2$d pour /v1/info — s’agit-il bien "
"d’un mint Cashu ?"

#: src/Admin/ValidateGlobalSettings.php:126
msgid ""
"Mint info response did not include the NUT capability list — is this a Cashu "
"mint?"
msgstr ""
"La réponse d’information du mint ne contient pas la liste des NUT pris en "
"charge — s’agit-il bien d’un mint Cashu ?"

#: src/Admin/ValidateGlobalSettings.php:133
msgid "customer Lightning → Cashu"
msgstr "paiement client Lightning → Cashu"

#: src/Admin/ValidateGlobalSettings.php:138
msgid "vendor Cashu → Lightning"
msgstr "paiement marchand Cashu → Lightning"

#. translators: 1: NUT identifier (e.g. NUT-04), 2: role description (e.g.
#. customer Lightning → Cashu)
#: src/Admin/ValidateGlobalSettings.php:148
msgid "Mint does not advertise %1$s (%2$s) — required for Lightning payments."
msgstr ""
"Le mint ne prend pas en charge %1$s (%2$s) — requis pour les paiements "
"Lightning."

#. translators: 1: NUT identifier (e.g. NUT-04), 2: role description (e.g.
#. customer Lightning → Cashu)
#: src/Admin/ValidateGlobalSettings.php:158
msgid ""
"Mint does not support BOLT11/sat under %1$s (%2$s) — required for Lightning "
"payments."
msgstr ""
"Le mint ne prend pas en charge BOLT11/sat pour %1$s (%2$s) — requis pour les "
"paiements Lightning."

#: src/Admin/ValidateGlobalSettings.php:195
msgid "Lightning address must be a valid lightning address (name@domain)."
msgstr ""
"L’adresse Lightning doit être une adresse Lightning valide (nom@domaine)."

#: src/Admin/ValidateGlobalSettings.php:225
msgid "Please enable at least one payment path (Unified / Cashu / Lightning)."
msgstr ""
"Veuillez activer au moins une option de paiement (Unifié / Cashu / "
"Lightning)."

#: src/Admin/ValidateGlobalSettings.php:240
msgid ""
"Unified payments need both Cashu and Lightning enabled — Unified has been "
"turned off."
msgstr ""
"Les paiements unifiés nécessitent l’activation de Cashu et de Lightning — "
"Unifié a été désactivé."

#: src/Admin/ValidateGlobalSettings.php:290
msgid ""
"Default tab was set to a disabled or unknown path — snapped to the first "
"enabled tab."
msgstr ""
"L’onglet par défaut était défini sur une option désactivée ou inconnue — "
"bascule effectuée vers le premier onglet activé."

#: src/CashuWCPlugin.php:197
msgid "Unauthorized"
msgstr "Non autorisé"

#. translators: 1: PHP Version string.
#: src/CashuWCPlugin.php:225
msgid "Your PHP version is %s but Cashu Payment plugin requires version 7.4+."
msgstr ""
"Votre version de PHP est %s, mais l’extension Cashu Payment nécessite la "
"version 7.4 ou supérieure."

#: src/CashuWCPlugin.php:234
msgid ""
"WooCommerce does not appear to be installed. Make sure you do before you "
"activate Cashu Payment Gateway."
msgstr ""
"WooCommerce ne semble pas être installé. Assurez-vous de l’installer avant "
"d’activer la passerelle de paiement Cashu."

#: src/CashuWCPlugin.php:242
msgid ""
"The PHP cURL extension is not installed. Make sure it is available otherwise "
"this plugin will not work."
msgstr ""
"L’extension PHP cURL n’est pas installée. Assurez-vous qu’elle est "
"disponible, sinon cette extension ne fonctionnera pas."

#. translators: 1: opening <a> tag to settings page 2: closing </a> tag
#: src/CashuWCPlugin.php:251
msgid "Plugin not configured yet, please %1$sconfigure the plugin here%2$s"
msgstr ""
"L’extension n’est pas encore configurée, veuillez %1$sla configurer ici%2$s"

#. translators: 1: opening <a> tag to the donation page, 2: closing </a> tag,
#. 3: opening <button> tag for "remind me later", 4: closing </button> tag, 5:
#. opening <button> tag for "stop reminding forever", 6: closing </button> tag.
#. Do not translate the HTML tags, keep the placeholder numbers.
#: src/CashuWCPlugin.php:268
msgid ""
"Thank you for using Cashu for WooCommerce! If you like the plugin, "
"%1$splease buy the developer a coffee%2$s. %3$sRemind me later%4$s %5$sStop "
"reminding me forever%6$s"
msgstr ""
"Merci d’utiliser Cashu pour WooCommerce ! Si vous aimez l’extension, "
"%1$soffrez un café au développeur%2$s. %3$sMe le rappeler plus tard%4$s "
"%5$sNe plus me le rappeler%6$s"

