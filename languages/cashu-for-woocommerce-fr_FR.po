#: src/Admin/GlobalSettings.php:13
msgid "Cashu Settings"
msgstr "Paramètres Cashu"

#: src/Admin/GlobalSettings.php:21
msgid "Cashu payments"
msgstr "Paiements Cashu"

#: src/Admin/GlobalSettings.php:23
msgid "Accept ecash payments directly to your lightning address via any Cashu mint."
msgstr "Acceptez des paiements ecash directement vers votre adresse Lightning via n’importe quel mint Cashu."

#: src/Admin/GlobalSettings.php:30
msgid "Enable Cashu"
msgstr "Activer Cashu"

#: src/Admin/GlobalSettings.php:32
msgid "Enable Cashu payments"
msgstr "Activer les paiements Cashu"

#: src/Admin/GlobalSettings.php:37
msgid "Lightning address"
msgstr "Adresse Lightning"

#: src/Admin/GlobalSettings.php:40
msgid "Where melted payments are sent, either a lightning address or LNURL."
msgstr "Destination des paiements fondus, soit une adresse Lightning, soit un LNURL."

#: src/Admin/GlobalSettings.php:48
msgid "Trusted Mint URL"
msgstr "URL du mint de confiance"

#: src/Admin/GlobalSettings.php:51
msgid "A mint you trust to act as your intermediary."
msgstr "Un mint en qui vous avez confiance pour servir d’intermédiaire."

#: src/Admin/GlobalSettings.php:59 src/CashuWCPlugin.php:341
msgid "Debug log"
msgstr "Journal de débogage"

#: src/Admin/GlobalSettings.php:61
msgid "Enable logging"
msgstr "Activer la journalisation"

#: src/Admin/GlobalSettings.php:65
#. translators: %s is a link to WooCommerce logs page
#, php-format
msgid "Log events to the WooCommerce logs, <a href=\"%s\">view logs</a>."
msgstr "Enregistrer les événements dans les journaux WooCommerce, <a href=\"%s\">voir les journaux</a>."

#: src/Admin/ValidateGlobalSettings.php:40
msgid "Trusted Mint URL must be a valid URL."
msgstr "L’URL du mint de confiance doit être une URL valide."

#: src/Admin/ValidateGlobalSettings.php:46
msgid "Trusted Mint URL must use https."
msgstr "L’URL du mint de confiance doit utiliser HTTPS."

#: src/Admin/ValidateGlobalSettings.php:66
msgid "Lightning address must be a valid lightning address (name@domain)."
msgstr "L’adresse Lightning doit être une adresse Lightning valide (nom@domaine)."

#: src/CashuWCPlugin.php:163
msgid "Unauthorized"
msgstr "Non autorisé"

#: src/CashuWCPlugin.php:191
#. translators: 1: PHP Version string.
#, php-format
msgid "Your PHP version is %s but Cashu Payment plugin requires version 7.4+."
msgstr "Votre version de PHP est %s, mais l’extension Cashu Payment nécessite la version 7.4 ou supérieure."

#: src/CashuWCPlugin.php:200
msgid ""
"WooCommerce does not appear to be installed. Make sure you do before you "
"activate Cashu Payment Gateway."
msgstr ""
"WooCommerce ne semble pas être installé. Assurez-vous de l’installer avant "
"d’activer la passerelle de paiement Cashu."

#: src/CashuWCPlugin.php:208
msgid ""
"The PHP cURL extension is not installed. Make sure it is available "
"otherwise this plugin will not work."
msgstr ""
"L’extension PHP cURL n’est pas installée. Assurez-vous qu’elle est "
"disponible, sinon cette extension ne fonctionnera pas."

#: src/CashuWCPlugin.php:217
#. translators: 1: opening <a> tag to settings page 2: closing </a> tag
#, php-format
msgid "Plugin not configured yet, please %1$sconfigure the plugin here%2$s"
msgstr "L’extension n’est pas encore configurée, veuillez %1$sla configurer ici%2$s"

#: src/CashuWCPlugin.php:234
#. translators: 1: opening <a> tag to the donation page, 2: closing </a> tag,
#. 3: opening <button> tag for "remind me later", 4: closing </button> tag, 5:
#. opening <button> tag for "stop reminding forever", 6: closing </button> tag.
#. Do not translate the HTML tags, keep the placeholder numbers.
#, php-format
msgid ""
"Thank you for using Cashu for WooCommerce! If you like the plugin, "
"%1$splease buy the developer a coffee%2$s. %3$sRemind me later%4$s %5$sStop "
"reminding me forever%6$s"
msgstr ""
"Merci d’utiliser Cashu pour WooCommerce ! Si vous aimez l’extension, "
"%1$soffrez un café au développeur%2$s. %3$sMe le rappeler plus tard%4$s "
"%5$sNe plus me le rappeler%6$s"

